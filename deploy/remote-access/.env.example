# =============================================================================
# HappyRanch Remote Access — environment variables (placeholders)
# =============================================================================
# Copy this file to .env and fill in REAL values.  NEVER commit .env to the repo.
#
# All variables are REQUIRED unless marked optional.

# ---------------------------------------------------------------------------
# Control-plane hostname
# ---------------------------------------------------------------------------
# The publicly-reachable FQDN of the headscale server.
# Example: headscale.example.com
# This MUST have a DNS A record pointing at the host's public IP.
HEADSCALE_SERVER_URL=https://changeme.example.com

# ---------------------------------------------------------------------------
# DERP relay hostname
# ---------------------------------------------------------------------------
# The publicly-reachable hostname for the DERP relay (STUN + DERP HTTPS).
# Usually the SAME as HEADSCALE_SERVER_URL (without the https:// prefix).
# Example: headscale.example.com
DERP_PUBLIC_HOSTNAME=changeme.example.com

# ---------------------------------------------------------------------------
# DERP STUN port (optional — defaults to 3478)
# ---------------------------------------------------------------------------
# If your cloud firewall maps STUN to a different port, set it here.
# DERP_STUN_PORT=3478

# ---------------------------------------------------------------------------
# TLS email for Let's Encrypt (optional — Caddy default)
# ---------------------------------------------------------------------------
# Caddy uses this email when requesting Let's Encrypt certificates.
# TLS_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Security note
# ---------------------------------------------------------------------------
# The preauth key and noise private key are managed INSIDE the container,
# not via env vars.  Use `headscale preauthkeys create` after bring-up to
# mint keys for devices.
